rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if user is an admin
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Settings Collection
    match /settings/{docId} {
      allow read: if true; // Everyone can read settings (delivery slots, store status)
      allow write: if isAdmin();
    }

    // Categories Collection
    match /categories/{catId} {
      allow read: if true; // Everyone can see categories
      allow write: if isAdmin();
    }

    // Products Collection
    match /products/{prodId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders Collection
    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null; // Riders and users need to update orders
      allow delete: if isAdmin();
    }

    // Users Collection
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }
  }
}
